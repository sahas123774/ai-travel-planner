<!DOCTYPE html>

<html>

<head>

   <title>
      Trip Result
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen">

   <!-- HEADER -->
   <header class="bg-white/80 backdrop-blur-xl border-b border-blue-100 shadow-md sticky top-0 z-50">

      <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col lg:flex-row justify-between items-center gap-5">

         <!-- LOGO -->
         <div>

            <h1 class="text-4xl font-extrabold text-blue-700">

               ✈️ AI Travel Planner

            </h1>

            <p class="text-gray-500 mt-2">

               Personalized AI-powered travel itinerary

            </p>

         </div>

         <!-- NAV -->
         <div class="flex items-center gap-4">

            <a
               href="/"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
            >
               🏠 Home
            </a>

            <a
               href="/history"
               class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
            >
               📜 History
            </a>

         </div>

      </div>

   </header>

   <!-- MAIN -->
   <main class="max-w-7xl mx-auto px-6 py-12">

      <!-- HERO IMAGE -->
      <div class="relative rounded-[40px] overflow-hidden shadow-2xl mb-14">

         <!-- IMAGE -->
         <img
            src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1600&auto=format&fit=crop"
            alt="<%= destination %>"
            class="w-full h-[450px] object-cover"
         >

         <!-- OVERLAY -->
         <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>

         <!-- TEXT -->
         <div class="absolute bottom-10 left-10 text-white">

            <h1 class="text-7xl font-extrabold mb-4 drop-shadow-2xl">

               🌍 <%= destination %>

            </h1>

            <p class="text-2xl text-gray-200 font-medium">

               AI Generated Smart Travel Plan

            </p>

         </div>

      </div>

      <!-- DAY PLANS -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

         <% dayPlans.forEach((day, index) => { %>

            <!-- CARD -->
            <div class="bg-white/80 backdrop-blur-xl border border-white/40 rounded-[35px] shadow-2xl overflow-hidden hover:shadow-blue-200/60 hover:-translate-y-2 transition duration-500">

               <!-- TOP -->
               <div class="bg-gradient-to-r from-blue-600 to-indigo-700 p-7 text-white">

                  <h2 class="text-4xl font-extrabold">

                     📅 Day <%= index + 1 %>

                  </h2>

               </div>

               <!-- CONTENT -->
               <div class="p-8">

                  <pre class="whitespace-pre-wrap text-gray-700 text-lg leading-relaxed font-medium"><%= day.trim() %></pre>

               </div>

            </div>

         <% }) %>

      </div>

      <!-- BOTTOM CTA -->
      <div class="mt-20 text-center">

         <a
            href="/"
            class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-10 py-5 rounded-3xl font-bold text-xl shadow-2xl hover:shadow-blue-300 transition duration-300 hover:-translate-y-1"
         >
            🚀 Plan Another Trip
         </a>

      </div>

   </main>

</body>

</html>