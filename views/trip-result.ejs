<!DOCTYPE html>

<html>

<head>

   <title>
      <%= destination %> | AI Travel Planner
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-sky-50 via-white to-indigo-100 min-h-screen">

   <!-- ================= HEADER ================= -->

   <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-slate-200 shadow-lg">

      <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col lg:flex-row justify-between items-center gap-6">

         <div>

            <h1 class="text-4xl font-extrabold text-blue-700">

               ✈️ AI Travel Planner

            </h1>

            <p class="text-slate-500 mt-2">

               Your AI Powered Travel Companion

            </p>

         </div>

         <div class="flex flex-wrap gap-4 justify-center">

            <a
               href="/"
               class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold transition shadow-lg">

               🏠 Home

            </a>

            <a
               href="/history"
               class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold transition shadow-lg">

               📜 History

            </a>

            <a
               href="/chat"
               class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-2xl font-bold transition shadow-lg">

               🤖 AI Chat

            </a>

         </div>

      </div>

   </header>

   <!-- ================= MAIN ================= -->

   <main class="max-w-7xl mx-auto px-6 py-10">

      <!-- ================= HERO ================= -->

      <div class="relative h-[550px] rounded-[40px] overflow-hidden shadow-2xl">

         <img

            src="<%= imageUrl %>"

            alt="<%= destination %>"

            class="absolute inset-0 w-full h-full object-cover"

         >

         <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>

         <div class="absolute bottom-12 left-12 text-white">

            <span class="inline-block bg-white/20 backdrop-blur-lg px-6 py-3 rounded-full font-bold border border-white/20">

               🤖 AI Generated Itinerary

            </span>

            <h1 class="text-7xl font-extrabold mt-8 drop-shadow-2xl">

               🌍 <%= destination %>

            </h1>

            <p class="text-2xl text-gray-200 mt-5">

               Personalized travel plan generated using Artificial Intelligence

            </p>

         </div>

      </div>

      <!-- ================= SUMMARY ================= -->

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">

         <!-- Destination -->

         <div class="bg-white rounded-3xl shadow-xl p-8 text-center hover:-translate-y-2 transition">

            <div class="text-5xl">

               🌍

            </div>

            <h3 class="text-gray-500 font-semibold mt-5">

               Destination

            </h3>

            <p class="text-3xl font-extrabold text-blue-600 mt-3">

               <%= destination %>

            </p>

         </div>

         <!-- Days -->

         <div class="bg-white rounded-3xl shadow-xl p-8 text-center hover:-translate-y-2 transition">

            <div class="text-5xl">

               📅

            </div>

            <h3 class="text-gray-500 font-semibold mt-5">

               Total Days

            </h3>

            <p class="text-3xl font-extrabold text-indigo-600 mt-3">

               <%= dayPlans.length %>

            </p>

         </div>

         <!-- AI -->

         <div class="bg-white rounded-3xl shadow-xl p-8 text-center hover:-translate-y-2 transition">

            <div class="text-5xl">

               🤖

            </div>

            <h3 class="text-gray-500 font-semibold mt-5">

               Generated By

            </h3>

            <p class="text-3xl font-extrabold text-emerald-600 mt-3">

               AI Planner

            </p>

         </div>

      </div>
            <!-- ================= MAP ================= -->

      <section class="mt-16">

         <div class="bg-white rounded-[35px] overflow-hidden shadow-2xl border border-slate-200">

            <!-- HEADER -->

            <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 p-8">

               <div class="flex justify-between items-center flex-wrap gap-4">

                  <div>

                     <h2 class="text-4xl font-extrabold text-white">

                        🗺 Destination Map

                     </h2>

                     <p class="text-blue-100 mt-2 text-lg">

                        Explore where your adventure begins.

                     </p>

                  </div>

                  <div class="bg-white/20 px-5 py-3 rounded-full text-white font-bold">

                     📍 <%= destination %>

                  </div>

               </div>

            </div>

            <!-- MAP -->

            <div class="p-8">

               <iframe

                  width="100%"

                  height="550"

                  loading="lazy"

                  style="border-radius:25px"

                  src="https://maps.google.com/maps?q=<%= destination %>&t=&z=12&ie=UTF8&iwloc=&output=embed">

               </iframe>

            </div>

         </div>

      </section>

      <!-- ================= ITINERARY ================= -->

      <section class="mt-20">

         <div class="text-center mb-14">

            <span class="bg-indigo-100 text-indigo-700 px-6 py-2 rounded-full font-bold">

               ✨ Personalized Plan

            </span>

            <h2 class="text-5xl font-extrabold text-slate-800 mt-6">

               Day-wise Itinerary

            </h2>

            <p class="text-gray-500 text-xl mt-4">

               Follow this AI generated travel schedule for your trip.

            </p>

         </div>

         <!-- DAY CARDS START HERE -->

         <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

            <% dayPlans.forEach((day, index) => { %>

<div
class="bg-white rounded-[35px] overflow-hidden shadow-xl hover:shadow-blue-300 hover:-translate-y-2 transition duration-500 border border-slate-200">

   <!-- CARD HEADER -->

   <div
   class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 p-7 text-white">

      <div class="flex justify-between items-center">

         <h2
         class="text-4xl font-extrabold">

            📅 Day <%= index+1 %>

         </h2>

         <span
         class="bg-white/20 px-4 py-2 rounded-full text-sm font-bold">

            AI Suggested

         </span>

      </div>

   </div>

   <!-- CARD BODY -->

   <div class="p-8">

      <div
      class="flex items-center gap-3 mb-6">

         <div
         class="h-4 w-4 rounded-full bg-green-500"></div>

         <h3
         class="text-xl font-bold text-slate-700">

            Daily Activities

         </h3>

      </div>

      <div
      class="bg-slate-50 rounded-2xl p-6">

         <p
         class="text-lg leading-9 whitespace-pre-line text-gray-700">

            <%= day.trim() %>

         </p>

      </div>

      <div
      class="mt-8 flex justify-between items-center">

         <span
         class="text-sm text-slate-500">

            ✨ Personalized by AI

         </span>

         <span
         class="bg-emerald-100 text-emerald-700 px-4 py-2 rounded-full font-semibold">

            Ready to Explore

         </span>

      </div>

   </div>

</div>

<% }) %>

</div>

</section>

<!-- ================= ACTION BUTTONS ================= -->

<section class="mt-20">

   <div class="bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-600 rounded-[40px] p-12 shadow-2xl text-center text-white">

      <h2 class="text-5xl font-extrabold">

         🎉 Your AI Travel Plan is Ready!

      </h2>

      <p class="text-xl mt-5 text-blue-100 max-w-3xl mx-auto">

         Save your itinerary, explore your trip history, or start planning your next unforgettable adventure.

      </p>

      <div class="flex flex-wrap justify-center gap-6 mt-12">

         <!-- Home -->

         <a
            href="/"
            class="bg-white text-blue-700 hover:bg-gray-100 px-8 py-4 rounded-2xl font-bold text-lg shadow-xl transition hover:scale-105">

            ✈ Plan Another Trip

         </a>

         <!-- History -->

         <a
            href="/history"
            class="bg-indigo-800 hover:bg-indigo-900 text-white px-8 py-4 rounded-2xl font-bold text-lg shadow-xl transition hover:scale-105">

            📜 View History

         </a>

      </div>

   </div>

</section>

</main>

</body>

</html>