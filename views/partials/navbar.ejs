<header
class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-xl shadow-md">

<div
class="max-w-7xl mx-auto px-4 md:px-6 py-4 flex flex-col lg:flex-row items-center justify-between gap-5">

   <!-- LOGO -->

   <a
   href="/"
   class="flex items-center gap-3 text-center lg:text-left">

      <div
      class="text-3xl md:text-4xl">

         ✈️

      </div>

      <div>

         <h1
         class="text-2xl md:text-3xl font-extrabold text-blue-700">

            AI Travel Planner

         </h1>

         <p
         class="text-gray-500 text-xs md:text-sm">

            Plan Smarter with AI

         </p>

      </div>

   </a>

   <!-- NAVIGATION -->

   <div
   class="flex flex-wrap justify-center lg:justify-end items-center gap-3 w-full lg:w-auto">

   <% if(isLoggedIn){ %>

      <a
      href="/"
      class="font-semibold hover:text-blue-600 transition px-3 py-2 rounded-lg hover:bg-blue-50">

         Home

      </a>

      <a
      href="/history"
      class="font-semibold hover:text-blue-600 transition px-3 py-2 rounded-lg hover:bg-blue-50">

         History

      </a>

      <a
      href="/chat"
      class="font-semibold hover:text-blue-600 transition px-3 py-2 rounded-lg hover:bg-blue-50">

         AI Chat

      </a>

      <a
      href="/welcome"
      class="font-semibold hover:text-blue-600 transition px-3 py-2 rounded-lg hover:bg-blue-50">

         Dashboard

      </a>

      <form
      action="/logout"
      method="POST">

         <button
         class="bg-red-500 hover:bg-red-600 text-white px-4 md:px-5 py-2 rounded-xl font-semibold transition">

            Logout

         </button>

      </form>

   <% } else { %>

      <a
      href="/login"
      class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl font-semibold transition">

         Login

      </a>

      <a
      href="/signup"
      class="bg-emerald-500 hover:bg-emerald-600 text-white px-5 py-2 rounded-xl font-semibold transition">

         Signup

      </a>

   <% } %>

   </div>

</div>

</header>