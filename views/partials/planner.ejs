class="w-full p-5 rounded-2xl border">

<input
type="number"
name="days"
placeholder="Number of Days"
required
class="w-full p-5 rounded-2xl border">

<input
type="number"
name="budget"
placeholder="Budget"
required
class="w-full p-5 rounded-2xl border">

<button
class="w-full bg-blue-600 hover:bg-blue-700 text-white py-5 rounded-2xl text-xl font-bold">

Generate AI Trip

</button>

