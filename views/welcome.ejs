<!DOCTYPE html>

<html>

<head>

   <title>
      Welcome Dashboard
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen">

   <!-- Background -->
   <div class="absolute top-0 left-0 w-96 h-96 bg-blue-200 rounded-full blur-3xl opacity-30 -translate-x-32 -translate-y-32"></div>

   <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-indigo-200 rounded-full blur-3xl opacity-30 translate-x-32 translate-y-32"></div>

   <!-- MAIN -->
   <main class="relative z-10 min-h-screen flex items-center justify-center px-6">

      <div class="max-w-5xl w-full bg-white/80 backdrop-blur-xl border border-white/50 rounded-[40px] shadow-2xl overflow-hidden">

         <div class="grid lg:grid-cols-2 items-center">

            <!-- LEFT -->
            <div class="p-14">

               <!-- Badge -->
               <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-5 py-2 rounded-full font-bold mb-8 shadow-sm">

                  ✈️ AI Powered Travel Planning

               </div>

               <!-- Heading -->
               <h1 class="text-6xl font-extrabold text-gray-800 leading-tight mb-6">

                  Welcome Back,

                  <span class="text-blue-700 block mt-2">
                     <%= user.username %> 👋
                  </span>

               </h1>

               <!-- Description -->
               <p class="text-xl text-gray-600 leading-relaxed mb-10 max-w-xl">

                  Plan dream vacations with AI-generated itineraries, hotel suggestions, travel tips, food recommendations, and personalized adventures.

               </p>

               <!-- Buttons -->
               <div class="flex flex-col sm:flex-row gap-5">

                  <!-- Make Trip -->
                  <a
                     href="/"
                     class="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-8 py-5 rounded-3xl font-bold text-lg text-center transition duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
                  >
                     🚀 Make A Trip
                  </a>

                  <!-- History -->
                  <a
                     href="/history"
                     class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-5 rounded-3xl font-bold text-lg text-center transition duration-300 shadow-xl hover:shadow-2xl hover:-translate-y-1"
                  >
                     📜 History
                  </a>

               </div>

               <!-- Logout -->
               <form
                  action="/logout"
                  method="POST"
                  class="mt-6"
               >

                  <button
                     type="submit"
                     class="w-full bg-red-500 hover:bg-red-600 text-white py-5 rounded-3xl font-bold text-lg transition duration-300 shadow-lg hover:shadow-2xl hover:-translate-y-1"
                  >
                     🚪 Logout
                  </button>

               </form>

            </div>

            <!-- RIGHT -->
            <div class="hidden lg:flex items-center justify-center p-12 bg-gradient-to-br from-blue-600 to-indigo-700 min-h-full">

               <div class="text-center text-white">

                  <div class="text-[180px] leading-none mb-4 animate-bounce">
                     🌍
                  </div>

                  <h2 class="text-5xl font-extrabold mb-6">
                     Explore The World
                  </h2>

                  <p class="text-blue-100 text-xl leading-relaxed max-w-md mx-auto">

                     Discover amazing destinations and create unforgettable memories powered by modern AI.

                  </p>

               </div>

            </div>

         </div>

      </div>

   </main>

</body>

</html>