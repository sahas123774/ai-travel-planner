<!DOCTYPE html>

<html>

<head>

   <title>
      AI Travel Planner
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen">

   <!-- HEADER -->
   <header class="bg-white/80 backdrop-blur-xl shadow-md border-b border-blue-100 sticky top-0 z-50">

      <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col lg:flex-row justify-between items-center gap-5">

         <!-- LOGO -->
         <div>

            <h1 class="text-4xl font-extrabold text-blue-700">

               ✈️ AI Travel Planner

            </h1>

            <p class="text-gray-500 mt-2">

               Plan your perfect journey with AI

            </p>

         </div>

         <!-- NAVIGATION -->
         <nav>

            <ul class="flex items-center gap-4 flex-wrap justify-center">

               <!-- Home -->
               <li>

                  <a
                     href="/"
                     class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
                  >
                     🏠 Home
                  </a>

               </li>

               <!-- History -->
               <li>

                  <a
                     href="/history"
                     class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
                  >
                     📜 History
                  </a>

               </li>

               <!-- AI CHAT -->
               <li>

                  <a
                     href="/chat"
                     class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
                  >
                     🤖 AI Chat
                  </a>

               </li>

               <!-- Dashboard -->
               <li>

                  <a
                     href="/welcome"
                     class="bg-cyan-600 hover:bg-cyan-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
                  >
                     👋 Dashboard
                  </a>

               </li>

               <!-- Logout -->
               <% if (isLoggedIn) { %>

                  <li>

                     <form
                        action="/logout"
                        method="POST"
                     >

                        <button
                           type="submit"
                           class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-2xl font-bold shadow-lg hover:shadow-2xl transition duration-300"
                        >
                           🚪 Logout
                        </button>

                     </form>

                  </li>

               <% } %>

            </ul>

         </nav>

      </div>

   </header>

   <!-- HERO SECTION -->
   <section class="max-w-7xl mx-auto px-6 py-16">

      <div class="relative rounded-[40px] overflow-hidden shadow-2xl">

         <!-- IMAGE -->
         <img
            src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1600&auto=format&fit=crop"
            class="w-full h-[550px] object-cover"
         >

         <!-- OVERLAY -->
         <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/30 to-transparent"></div>

         <!-- TEXT -->
         <div class="absolute inset-0 flex flex-col justify-center px-12 lg:px-20">

            <div class="max-w-3xl">

               <div class="inline-flex items-center gap-3 bg-white/20 backdrop-blur-md border border-white/20 text-white px-6 py-3 rounded-full font-bold mb-8 shadow-lg">

                  🌍 AI Powered Smart Travel Planning

               </div>

               <h1 class="text-6xl lg:text-8xl font-extrabold text-white leading-tight drop-shadow-2xl mb-8">

                  Discover
                  Your Next
                  Adventure

               </h1>

               <p class="text-2xl text-gray-200 leading-relaxed mb-10 max-w-2xl">

                  Generate personalized itineraries, explore destinations,
                  chat with AI travel assistant, and plan unforgettable trips.

               </p>

               <!-- BUTTONS -->
               <div class="flex flex-col sm:flex-row gap-5">

                  <a
                     href="#planner"
                     class="bg-blue-600 hover:bg-blue-700 text-white px-10 py-5 rounded-3xl font-bold text-xl shadow-2xl hover:shadow-blue-300 transition duration-300 hover:-translate-y-1 text-center"
                  >
                     🚀 Plan A Trip
                  </a>

                  <a
                     href="/chat"
                     class="bg-purple-600 hover:bg-purple-700 text-white px-10 py-5 rounded-3xl font-bold text-xl shadow-2xl hover:shadow-purple-300 transition duration-300 hover:-translate-y-1 text-center"
                  >
                     🤖 Talk To AI
                  </a>

               </div>

            </div>

         </div>

      </div>

   </section>

   <!-- PLANNER -->
   <main
      id="planner"
      class="max-w-5xl mx-auto px-6 pb-20"
   >

      <div class="bg-white/80 backdrop-blur-xl border border-white/40 rounded-[40px] shadow-2xl p-10">

         <!-- TITLE -->
         <div class="text-center mb-12">

            <h2 class="text-5xl font-extrabold text-blue-700 mb-5">

               ✈️ Plan Your Dream Trip

            </h2>

            <p class="text-xl text-gray-600">

               AI will generate your personalized travel itinerary

            </p>

         </div>

         <!-- FORM -->
         <form
            action="/generate-trip"
            method="POST"
            class="space-y-8"
         >

            <!-- Destination -->
            <div>

               <label class="block text-xl font-bold text-gray-700 mb-3">

                  🌍 Destination

               </label>

               <input
                  type="text"
                  name="destination"
                  placeholder="Enter destination..."
                  class="w-full p-5 rounded-2xl border border-gray-300 focus:outline-none focus:ring-4 focus:ring-blue-300 text-lg"
                  required
               >

            </div>

            <!-- Days -->
            <div>

               <label class="block text-xl font-bold text-gray-700 mb-3">

                  📅 Number Of Days

               </label>

               <input
                  type="number"
                  name="days"
                  placeholder="Enter number of days..."
                  class="w-full p-5 rounded-2xl border border-gray-300 focus:outline-none focus:ring-4 focus:ring-blue-300 text-lg"
                  required
               >

            </div>

            <!-- Budget -->
            <div>

               <label class="block text-xl font-bold text-gray-700 mb-3">

                  💰 Budget Amount

               </label>

               <input
                  type="number"
                  name="budget"
                  placeholder="Enter your budget in ₹..."
                  class="w-full p-5 rounded-2xl border border-gray-300 focus:outline-none focus:ring-4 focus:ring-blue-300 text-lg"
                  required
               >

            </div>

            <!-- BUTTON -->
            <button
               type="submit"
               class="w-full bg-blue-600 hover:bg-blue-700 text-white py-5 rounded-3xl font-bold text-2xl shadow-2xl hover:shadow-blue-300 transition duration-300 hover:-translate-y-1"
            >
               🚀 Generate AI Trip
            </button>

         </form>

      </div>

   </main>

</body>

</html>