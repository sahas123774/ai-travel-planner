<!DOCTYPE html>

<html>

<head>

   <title>
      AI Travel Planner
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen">

   <!-- HEADER -->
   <header class="bg-white/80 backdrop-blur-lg shadow-md border-b border-blue-100 sticky top-0 z-50">

      <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col lg:flex-row justify-between items-center gap-5">

         <!-- Logo -->
         <div class="flex items-center gap-4">

            <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center shadow-sm">

               ✈️

            </div>

            <div>

               <h1 class="text-3xl font-extrabold text-blue-700">
                  AI Travel Planner
               </h1>

               <p class="text-sm text-gray-500">
                  Plan smart trips using AI
               </p>

            </div>

         </div>

         <!-- NAVIGATION -->
         <nav>

            <ul class="flex items-center gap-4 flex-wrap justify-center">

               <!-- HOME -->
               <li>

                  <a
                     href="/"
                     class="text-gray-700 font-semibold hover:text-blue-600 transition"
                  >
                     🏠 Home
                  </a>

               </li>

               <!-- HISTORY -->
               <li>

                  <a
                     href="/history"
                     class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                  >
                     📜 History
                  </a>

               </li>

               <!-- USERNAME -->
               <% if (isLoggedIn) { %>

                  <li>

                     <div class="bg-blue-50 text-blue-700 px-5 py-3 rounded-2xl font-bold shadow-sm">

                        👋 <%= user.username %>

                     </div>

                  </li>

               <% } %>

               <!-- LOGIN / SIGNUP -->
               <% if (!isLoggedIn) { %>

                  <li>

                     <a
                        href="/login"
                        class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                     >
                        🔐 Login
                     </a>

                  </li>

                  <li>

                     <a
                        href="/signup"
                        class="bg-green-600 hover:bg-green-700 text-white px-5 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                     >
                        🚀 Signup
                     </a>

                  </li>

               <% } %>

               <!-- LOGOUT -->
               <% if (isLoggedIn) { %>

                  <li>

                     <form
                        action="/logout"
                        method="POST"
                     >

                        <button
                           type="submit"
                           class="bg-red-500 hover:bg-red-600 text-white px-5 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                        >
                           🚪 Logout
                        </button>

                     </form>

                  </li>

               <% } %>

            </ul>

         </nav>

      </div>

   </header>

   <!-- MAIN -->
   <main class="max-w-7xl mx-auto px-6 py-16">

      <!-- HERO -->
      <section class="mb-16">

         <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-blue-100">

            <div class="grid lg:grid-cols-2 gap-10 items-center p-10">

               <!-- LEFT -->
               <div>

                  <h1 class="text-6xl font-extrabold text-gray-800 leading-tight mb-6">

                     Plan Your Dream Trip With AI ✈️

                  </h1>

                  <p class="text-xl text-gray-600 leading-relaxed mb-10">

                     Generate smart travel itineraries with destination ideas, hotels, food recommendations, and transport guidance powered by AI.

                  </p>

                  <!-- FEATURES -->
                  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

                     <!-- FEATURE -->
                     <div class="bg-blue-50 p-5 rounded-2xl border border-blue-100">

                        <div class="text-4xl mb-3">
                           🌍
                        </div>

                        <h3 class="font-bold text-blue-700 text-lg mb-2">
                           Smart Destinations
                        </h3>

                        <p class="text-gray-600 text-sm">
                           AI suggests amazing places to explore.
                        </p>

                     </div>

                     <!-- FEATURE -->
                     <div class="bg-indigo-50 p-5 rounded-2xl border border-indigo-100">

                        <div class="text-4xl mb-3">
                           🏨
                        </div>

                        <h3 class="font-bold text-indigo-700 text-lg mb-2">
                           Hotel Suggestions
                        </h3>

                        <p class="text-gray-600 text-sm">
                           Budget-friendly hotel recommendations.
                        </p>

                     </div>

                     <!-- FEATURE -->
                     <div class="bg-green-50 p-5 rounded-2xl border border-green-100">

                        <div class="text-4xl mb-3">
                           🍜
                        </div>

                        <h3 class="font-bold text-green-700 text-lg mb-2">
                           Food Recommendations
                        </h3>

                        <p class="text-gray-600 text-sm">
                           Discover local foods and famous restaurants.
                        </p>

                     </div>

                     <!-- FEATURE -->
                     <div class="bg-yellow-50 p-5 rounded-2xl border border-yellow-100">

                        <div class="text-4xl mb-3">
                           🚕
                        </div>

                        <h3 class="font-bold text-yellow-700 text-lg mb-2">
                           Travel Tips
                        </h3>

                        <p class="text-gray-600 text-sm">
                           Get transport and budget planning tips.
                        </p>

                     </div>

                  </div>

               </div>

               <!-- RIGHT -->
               <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-3xl p-10 shadow-inner">

                  <h2 class="text-4xl font-extrabold text-blue-700 mb-8 text-center">

                     🚀 Generate Your Trip

                  </h2>

                  <!-- FORM -->
                  <form
                     action="/generate-trip"
                     method="POST"
                     class="space-y-6"
                     onsubmit="showLoader()"
                  >

                     <!-- DESTINATION -->
                     <div>

                        <label class="block mb-2 font-semibold text-gray-700">

                           Destination

                        </label>

                        <input
                           type="text"
                           name="destination"
                           placeholder="Goa"
                           required
                           class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-blue-200 outline-none"
                        >

                     </div>

                     <!-- DAYS -->
                     <div>

                        <label class="block mb-2 font-semibold text-gray-700">

                           Number of Days

                        </label>

                        <input
                           type="number"
                           name="days"
                           placeholder="3"
                           required
                           class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-blue-200 outline-none"
                        >

                     </div>

                     <!-- BUDGET -->
                     <div>

                        <label class="block mb-2 font-semibold text-gray-700">

                           Budget (₹)

                        </label>

                        <input
                           type="number"
                           name="budget"
                           placeholder="20000"
                           required
                           class="w-full px-5 py-4 rounded-2xl border border-gray-300 focus:ring-4 focus:ring-blue-200 outline-none"
                        >

                     </div>

                     <!-- BUTTON -->
                     <button
                        id="generateBtn"
                        type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-2xl font-bold text-lg transition duration-300 shadow-lg hover:shadow-2xl"
                     >
                        ✨ Generate AI Trip
                     </button>

                  </form>

               </div>

            </div>

         </div>

      </section>

   </main>

   <!-- LOADER -->
   <script>

      function showLoader() {

         const btn =
         document.getElementById(
            'generateBtn'
         );

         btn.innerHTML =
         '⏳ Generating Trip...';

         btn.disabled = true;

         btn.classList.add(
            'opacity-70'
         );

      }

   </script>

</body>

</html>