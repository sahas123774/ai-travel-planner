<!DOCTYPE html>

<html>

<head>

   <title>
      Page Not Found
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen flex items-center justify-center px-6">

   <div class="max-w-3xl w-full bg-white rounded-3xl shadow-2xl overflow-hidden border border-blue-100">

      <div class="p-12 text-center">

         <!-- Emoji -->
         <div class="text-8xl mb-6">
            😵
         </div>

         <!-- 404 -->
         <h1 class="text-7xl font-extrabold text-blue-700 mb-4">
            404
         </h1>

         <!-- Heading -->
         <h2 class="text-4xl font-bold text-gray-800 mb-6">

            Oops! Page Not Found

         </h2>

         <!-- Description -->
         <p class="text-gray-600 text-xl leading-relaxed mb-10">

            The page you are looking for does not exist or may have been moved.

         </p>

         <!-- Buttons -->
         <div class="flex flex-col sm:flex-row justify-center gap-5">

            <!-- Home -->
            <a
               href="/"
               class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-2xl font-bold text-lg transition duration-300 shadow-lg hover:shadow-2xl"
            >
               🏠 Go Home
            </a>

            <!-- History -->
            <a
               href="/history"
               class="bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-2xl font-bold text-lg transition duration-300 shadow-lg hover:shadow-2xl"
            >
               📜 View History
            </a>

         </div>

      </div>

   </div>

</body>

</html>