<!DOCTYPE html>

<html>

<head>

   <title>
      Trip History
   </title>

   <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-100 min-h-screen">

   <!-- HEADER -->
   <header class="bg-white/80 backdrop-blur-lg shadow-md border-b border-blue-100 sticky top-0 z-50">

      <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col lg:flex-row justify-between items-center gap-5">

         <!-- Logo -->
         <div class="flex items-center gap-4">

            <div class="w-14 h-14 bg-blue-100 rounded-2xl flex items-center justify-center shadow-sm">

               📜

            </div>

            <div>

               <h1 class="text-3xl font-extrabold text-blue-700">
                  Trip History
               </h1>

               <p class="text-sm text-gray-500">
                  Your previously generated AI trips
               </p>

            </div>

         </div>

         <!-- Navigation -->
         <nav>

            <ul class="flex items-center gap-4 flex-wrap justify-center">

               <!-- Home -->
               <li>

                  <a
                     href="/"
                     class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                  >
                     🏠 Home
                  </a>

               </li>

               <!-- Welcome -->
               <li>

                  <a
                     href="/welcome"
                     class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                  >
                     👋 Dashboard
                  </a>

               </li>

               <!-- Logout -->
               <% if (isLoggedIn) { %>

                  <li>

                     <form
                        action="/logout"
                        method="POST"
                     >

                        <button
                           type="submit"
                           class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-2xl font-bold shadow-md hover:shadow-xl transition duration-300"
                        >
                           🚪 Logout
                        </button>

                     </form>

                  </li>

               <% } %>

            </ul>

         </nav>

      </div>

   </header>

   <!-- MAIN -->
   <main class="max-w-7xl mx-auto px-6 py-16">

      <!-- EMPTY STATE -->
      <% if (trips.length === 0) { %>

         <div class="bg-white rounded-3xl shadow-2xl border border-blue-100 p-16 text-center">

            <!-- Emoji -->
            <div class="text-8xl mb-8">
               ✈️
            </div>

            <!-- Heading -->
            <h1 class="text-5xl font-extrabold text-blue-700 mb-6">

               No Trips Yet

            </h1>

            <!-- Description -->
            <p class="text-gray-600 text-xl leading-relaxed max-w-2xl mx-auto mb-10">

               You have not generated any AI travel itineraries yet.
               Start exploring destinations and create your dream trip now.

            </p>

            <!-- Button -->
            <a
               href="/"
               class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-10 py-5 rounded-2xl font-bold text-xl transition duration-300 shadow-lg hover:shadow-2xl"
            >
               🚀 Generate Your First Trip
            </a>

         </div>

      <% } else { %>

         <!-- Heading -->
         <div class="mb-12 text-center">

            <h1 class="text-6xl font-extrabold text-blue-700 mb-4">

               📜 Your Travel History

            </h1>

            <p class="text-xl text-gray-600">

               Explore all your AI-generated travel plans

            </p>

         </div>

         <!-- Trips Grid -->
         <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

            <% trips.forEach(trip => { %>

               <!-- Trip Card -->
               <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-blue-100 hover:shadow-2xl hover:-translate-y-2 transition duration-500">

                  <!-- TOP -->
                  <div class="bg-gradient-to-r from-blue-600 to-indigo-600 p-8 text-white">

                     <div class="flex justify-between items-start gap-4">

                        <div>

                           <h2 class="text-4xl font-extrabold mb-3">

                              🌍 <%= trip.destination %>

                           </h2>

                           <p class="text-blue-100 text-lg">

                              <%= trip.days %> Days Adventure

                           </p>

                        </div>

                        <div class="bg-white/20 px-5 py-3 rounded-2xl backdrop-blur-md">

                           <p class="text-2xl font-extrabold">

                              ₹ <%= trip.budget %>

                           </p>

                        </div>

                     </div>

                  </div>

                  <!-- CONTENT -->
                  <div class="p-8">

                     <h3 class="text-2xl font-bold text-gray-800 mb-5">

                        ✨ AI Itinerary

                     </h3>

                     <!-- Trip Plan -->
                     <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 max-h-[400px] overflow-y-auto">

                        <pre class="whitespace-pre-wrap text-gray-700 leading-relaxed text-base"><%= trip.tripPlan %></pre>

                     </div>

                     <!-- Buttons -->
                     <div class="flex flex-col sm:flex-row gap-4 mt-6">

                        <!-- Download PDF -->
                        <a
                           href="/download-trip/<%= trip._id %>"
                           class="flex-1 text-center bg-green-600 hover:bg-green-700 text-white px-6 py-4 rounded-2xl font-bold transition duration-300 shadow-lg hover:shadow-2xl"
                        >
                           📄 Download PDF
                        </a>

                        <!-- Generate Again -->
                        <a
                           href="/"
                           class="flex-1 text-center bg-blue-600 hover:bg-blue-700 text-white px-6 py-4 rounded-2xl font-bold transition duration-300 shadow-lg hover:shadow-2xl"
                        >
                           🚀 Generate Again
                        </a>

                     </div>

                  </div>

               </div>

            <% }) %>

         </div>

      <% } %>

   </main>

</body>

</html>